# ===============================================
# Google Calendar 整合配置
# ===============================================

# 你的 Google Calendar ID
# 可在 Google Calendar 設定 > 整合的日曆 > 日曆設定中找到
# 格式: xxx@gmail.com 或 xxx@group.calendar.google.com
GOOGLE_CALENDAR_ID=tjmfamilyc0@gmail.com

# Service Account 金鑰檔案路徑
# 本機開發：完整路徑 /Users/yourname/Rollcall-Secrets/service-account.json
# 伺服器部署：/home/username/.config/rollcall/service-account.json
GOOGLE_SERVICE_ACCOUNT_KEY=/Users/yourname/Rollcall-Secrets/service-account.json

# ===============================================
# Node.js 環境設定
# ===============================================
NODE_ENV=development

# ===============================================
# 資料庫設定（保留你現有的配置）
# ===============================================
# DATABASE_URL=mongodb://localhost:27017/rollcall
# DB_HOST=localhost
# DB_PORT=27017

# ===============================================
# 伺服器設定
# ===============================================
PORT=3000
HOST=localhost

# ===============================================
# 其他你現有的配置保持不變
# ===============================================
